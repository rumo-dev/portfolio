---
interface Props {
  images: string[];
  isComparison?: boolean;
}

const { images, isComparison = false } = Astro.props;
---

<div class={`image-container ${isComparison ? 'grid-2' : 'grid-1'}`}>
  {
    images.map((src) => (
      <div class="image-wrapper">
        <img src={src} alt="" loading="lazy" />
      </div>
    ))
  }
</div>

<style>
.image-container {
  width: 100%;
  margin: 1.5rem 0;
}

.grid-1 {
  display: block;
}

.grid-2 {
  display: grid;

  grid-template-columns: repeat(2, minmax(0, 1fr));

  gap: 1rem;

  /* 高さを揃える */
  align-items: stretch;
}

.image-wrapper {
  margin: 0;
  padding: 0;

  /* ← これ重要 */
  line-height: 0;

  overflow: hidden;

  border-radius: 10px;
}

.image-wrapper img {
  display: block;

  width: 100%;
  height: auto;

  vertical-align: top;

  border-radius: inherit;

  background: #1a1a1a;
}

@media (max-width: 768px) {
  .grid-2 {
    grid-template-columns: 1fr;
  }
}
</style>